# ─── TrustFlow Environment Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your actual credentials.
# NEVER commit the .env file to git.

# ── PostgreSQL (REQUIRED) ─────────────────────────────────────────────────────
# Both POSTGRES_PASSWORD and JWT_SECRET_KEY MUST be set — the stack refuses to
# start without them.
POSTGRES_DB=trustflow
POSTGRES_USER=trustflow
POSTGRES_PASSWORD=change-this-to-a-strong-password
# Only needed when running outside Docker (compose builds this URL itself):
# DATABASE_URL=postgresql://trustflow:change-this@localhost:5432/trustflow

# ── JWT Auth (REQUIRED) ───────────────────────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-this-to-a-long-random-string

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI Provider (OpenRouter) ──────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get token from @BotFather; chat ID via /start then bot getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── WhatsApp Alerts (Twilio) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TO_WHATSAPP=

# ── Alert Channel Toggles ─────────────────────────────────────────────────────
ENABLE_TELEGRAM=false
ENABLE_WHATSAPP=false
ENABLE_EMAIL=false
ENABLE_SLACK=false
ENABLE_WEBHOOK=false

# ── Email Alerts (optional) ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# ── Slack Alerts (optional) ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Generic Webhook (optional) ────────────────────────────────────────────────
ALERT_WEBHOOK_URL=

# ── Threat Intelligence (optional but strongly recommended) ───────────────────
ABUSEIPDB_API_KEY=
OTX_API_KEY=
VIRUSTOTAL_API_KEY=

# ── Frontend build-time API URL ───────────────────────────────────────────────
# In production, set this to your public API origin (e.g., https://api.example.com)
VITE_API_URL=http://localhost:8000
