# ─── ThreatPulse Environment Configuration ────────────────────────────────────
# Copy this file to .env and fill in your actual credentials.
# NEVER commit the .env file to git.

# ── AI Provider (OpenRouter) ──────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Telegram Bot ── (bot: t.me/Threat_pulse_bot) ─────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Get your chat ID: message the bot /start, then go to
# https://api.telegram.org/bot<TOKEN>/getUpdates and look for "chat":{"id":...}
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── WhatsApp Alerts (Twilio) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TO_WHATSAPP=whatsapp:+1234567890

# ── Alert Channel Toggles ─────────────────────────────────────────────────────
ENABLE_TELEGRAM=true
ENABLE_WHATSAPP=false
ENABLE_EMAIL=false
ENABLE_SLACK=false
ENABLE_WEBHOOK=false

# ── Email Alerts (optional) ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=threatpulse@your-org.com
EMAIL_TO=soc-team@your-org.com

# ── Slack Alerts (optional) ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook

# ── Generic Webhook (optional) ────────────────────────────────────────────────
ALERT_WEBHOOK_URL=https://your-webhook-endpoint.com/alerts

# ── Threat Intelligence ───────────────────────────────────────────────────────
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
OTX_API_KEY=your_alienvault_otx_api_key_here
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# ── Database (optional - SQLite used if not set) ──────────────────────────────
DATABASE_URL=postgresql://threatpulse:threatpulse_secret@localhost:5432/threatpulse
POSTGRES_USER=threatpulse
POSTGRES_PASSWORD=threatpulse_secret

# ── Redis (optional, for caching) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0