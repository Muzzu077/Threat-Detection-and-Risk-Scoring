# ─── TrustFlow Environment Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your actual credentials.
# NEVER commit the .env file to git.

# ── PostgreSQL (REQUIRED) ─────────────────────────────────────────────────────
# Both POSTGRES_PASSWORD and JWT_SECRET_KEY MUST be set — the stack refuses to
# start without them.
POSTGRES_DB=trustflow
POSTGRES_USER=trustflow
POSTGRES_PASSWORD=change-this-to-a-strong-password
# Only needed when running outside Docker (compose builds this URL itself):
# DATABASE_URL=postgresql://trustflow:change-this@localhost:5432/trustflow

# ── JWT Auth (REQUIRED) ───────────────────────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-this-to-a-long-random-string

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI Provider (OpenRouter) ──────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get token from @BotFather; chat ID via /start then bot getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── WhatsApp Alerts (Twilio) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TO_WHATSAPP=

# ── Alert Channel Toggles ─────────────────────────────────────────────────────
ENABLE_TELEGRAM=false
ENABLE_WHATSAPP=false
ENABLE_EMAIL=false
ENABLE_SLACK=false
ENABLE_WEBHOOK=false

# ── Email Alerts (optional) ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# ── Slack Alerts (optional) ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Generic Webhook (optional) ────────────────────────────────────────────────
ALERT_WEBHOOK_URL=

# ── Threat Intelligence (optional but strongly recommended) ───────────────────
ABUSEIPDB_API_KEY=
OTX_API_KEY=
VIRUSTOTAL_API_KEY=

# ── Frontend build-time API URL ───────────────────────────────────────────────
# In production, set this to your public API origin (e.g., https://api.example.com)
VITE_API_URL=/

# ─── Phase 4: Scale-out (all optional) ────────────────────────────────────────

# ── Kafka streaming ───────────────────────────────────────────────────────────
# When set, every ingested event is also published to Kafka at this/these
# brokers. Leave blank to disable. Topic defaults to trustflow.events.
KAFKA_BROKERS=
KAFKA_EVENTS_TOPIC=trustflow.events

# ── Neo4j attack-graph backend ────────────────────────────────────────────────
# When set, ingested events with risk >= 30 are mirrored to Neo4j and the
# /api/attack-graph/neo4j endpoint serves graphs from the database. Leave
# blank to keep using the in-process NetworkX backend.
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── STIX/TAXII threat-intel feed ──────────────────────────────────────────────
# When set, admins can pull IOC bundles via /api/threat-intel/stix/pull and
# the IP/domain lookup path consults the cache before external APIs.
TAXII_SERVER_URL=
TAXII_USERNAME=
TAXII_PASSWORD=
TAXII_COLLECTIONS=

# ── Per-API-key rate limiting (Phase 1) ───────────────────────────────────────
# Sliding window enforced per key in Redis.
API_KEY_RATE_LIMIT_REQUESTS=1000
API_KEY_RATE_LIMIT_WINDOW=60
